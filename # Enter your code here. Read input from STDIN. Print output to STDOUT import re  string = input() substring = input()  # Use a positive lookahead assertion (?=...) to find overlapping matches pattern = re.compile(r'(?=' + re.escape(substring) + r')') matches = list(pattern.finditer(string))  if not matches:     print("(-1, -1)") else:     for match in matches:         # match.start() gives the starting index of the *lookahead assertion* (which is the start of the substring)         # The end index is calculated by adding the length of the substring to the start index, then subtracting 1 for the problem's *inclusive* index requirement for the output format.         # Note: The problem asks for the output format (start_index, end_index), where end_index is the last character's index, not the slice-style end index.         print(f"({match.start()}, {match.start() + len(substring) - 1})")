# Enter your code here. Read input from STDIN. Print output to STDOUT
import re

vowels = "AEIOUaeiou"
consonants = "QWRTYPSDFGHJKLZXCVBNMqwrtypsdfghjklzxcvbnm"

# Input string
s = input()

# The regex uses positive lookbehind (?<=...) and positive lookahead (?=...) 
# to check for surrounding consonants without including them in the match itself.
# The capturing group (...) is around the vowels we want to extract.
pattern = rf"(?<=[{consonants}])([{vowels}]{{2,}})(?=[{consonants}])"

# Use re.findall() to get a list of all matching groups (the vowels)
matches = re.findall(pattern, s)

# Print the results or -1 if no matches are found
if matches:
    for match in matches:
        print(match)
else:
    print("-1")
