def fibonacci(n):
    """
    Generates a list of the first n Fibonacci numbers.
    The sequence starts with 0 and 1.
    """
    if n == 0:
        return []
    elif n == 1:
        return [0]
    else:
        # Start with the first two numbers
        fib_numbers = [0, 1]
        # Generate the rest of the numbers
        for i in range(2, n):
            next_fib = fib_numbers[-1] + fib_numbers[-2]
            fib_numbers.append(next_fib)
        return fib_numbers[:n] # Ensure only the first N are returned
