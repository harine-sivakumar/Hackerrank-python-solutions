if __name__ == '__main__':
    N = int(input())
    l = []
    for i in range(N):
        # Read the command line and split it into a list of strings
        command_args = input().split()
        
        # The first element is the command name
        command = command_args[0]
        
        # Perform operations based on the command using if-elif statements
        if command == 'insert':
            # insert i e: arguments at index 1 (i) and 2 (e)
            l.insert(int(command_args[1]), int(command_args[2]))
        elif command == 'print':
            # print: no arguments
            print(l)
        elif command == 'remove':
            # remove e: argument at index 1 (e)
            l.remove(int(command_args[1]))
        elif command == 'append':
            # append e: argument at index 1 (e)
            l.append(int(command_args[1]))
        elif command == 'sort':
            # sort: no arguments
            l.sort()
        elif command == 'pop':
            # pop: no arguments
            l.pop()
        elif command == 'reverse':
            # reverse: no arguments
            l.reverse()

