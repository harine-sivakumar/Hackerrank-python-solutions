# Enter your code here. Read input from STDIN. Print output to STDOUT
import re

def validate_phone_numbers():
    # Read the number of test cases
    n = int(input())
    
    # Define the regex pattern:
    # ^[789]: Starts with 7, 8, or 9
    # \\d{9}: Followed by exactly 9 digits (0-9)
    # $: Matches the end of the string, ensuring exactly 10 digits
    pattern = r"^[789]\d{9}$"
    
    for _ in range(n):
        phone_number = input()
        # Use re.match or re.fullmatch to check if the entire string matches the pattern
        if re.match(pattern, phone_number):
            print("YES")
        else:
            print("NO")

validate_phone_numbers()
