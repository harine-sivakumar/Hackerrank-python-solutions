import sys

if __name__ == "__main__":
    # Read N (rows) and M (columns)
    try:
        nm = input().split()
        n = int(nm[0])
        m = int(nm[1])
    except ValueError:
        # Handle cases where the input might be on a single line with space
        # This is a common pattern in HackerRank challenges
        pass 

    arr = []
    # Read the data into a list of lists
    for _ in range(n):
        arr.append(list(map(int, input().rstrip().split())))

    # Read the column index K
    k = int(input().strip())

    # Sort the array based on the Kth column using a lambda key
    sorted_arr = sorted(arr, key=lambda x: x[k])

    # Print the sorted table
    for row in sorted_arr:
        # Unpack the list for space-separated output
        print(*row)
