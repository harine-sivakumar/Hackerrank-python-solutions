import sys
from datetime import datetime

def time_delta(t1, t2):
    # Define the required format string to parse the timestamps
    fmt = "%a %d %b %Y %H:%M:%S %z"
    
    # Convert the string timestamps to datetime objects
    dt1 = datetime.strptime(t1, fmt)
    dt2 = datetime.strptime(t2, fmt)
    
    # Calculate the absolute difference (timedelta object)
    # The result will automatically handle the time zone differences
    delta = abs(dt1 - dt2)
    
    # Return the total difference in seconds as a string
    return str(int(delta.total_seconds()))

