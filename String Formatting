def print_formatted(number):
    # Calculate the width based on the length of the binary representation of 'number'
    width = len(f"{number:b}")
    
    # Iterate from 1 to 'number' (inclusive)
    for i in range(1, number + 1):
        # Use f-strings for formatting and alignment
        # :>{width}d : Decimal, right-justified to 'width'
        # :>{width}o : Octal, right-justified to 'width'
        # :>{width}X : Hexadecimal (capitalized), right-justified to 'width'
        # :>{width}b : Binary, right-justified to 'width'
        print(f"{i:{width}d} {i:{width}o} {i:{width}X} {i:{width}b}")


if __name__ == '__main__':
    n = int(input())
    print_formatted(n)
